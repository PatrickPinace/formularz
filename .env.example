# NocoDB Configuration
# URL do instancji NocoDB (bez końcowego slasha)
NOCODB_URL=https://your-nocodb-instance.com

# Token autoryzacyjny NocoDB (znajdziesz go w ustawieniach konta)
NOCODB_TOKEN=your-nocodb-token-here

# ID tabeli form_submissions w NocoDB
NOCODB_FORM_SUBMISSIONS_TABLE_ID=your-table-id

# ID tabeli form_content w NocoDB (opcjonalne - do dynamicznych treści)
NOCODB_FORM_CONTENT_TABLE_ID=your-content-table-id

# Inne opcjonalne konfiguracje
# PORT=3000
