---
import '../styles/global.css';
import FormWizard from '../components/form/FormWizard';
import { steps } from '../lib/flow';
import { getFormContent } from '../lib/content';

const content = await getFormContent();

// Sprawdź czy jest UUID w query params (odtworzenie draftu)
const url = new URL(Astro.request.url);
const draftUuid = url.searchParams.get('uuid');

let initialAnswers = {};
let submissionUuid = undefined;

if (draftUuid) {
  try {
    const res = await fetch(`${url.origin}/api/form-draft/${draftUuid}`);
    if (res.ok) {
      const data = await res.json();
      initialAnswers = data.answers || {};
      submissionUuid = data.submission_uuid;
    }
  } catch (err) {
    console.error('Failed to load draft:', err);
  }
}
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Formularz rejestracyjny - Medi3</title>
  </head>
  <body class="bg-neutral-50 font-sans text-neutral-800 antialiased">
    <div class="min-h-screen py-4 px-4 sm:py-8">
      <div class="mx-auto w-full max-w-[480px] sm:max-w-[640px]">
        <div class="bg-white rounded-lg shadow-sm p-6 sm:p-8 space-y-6">
          <h1 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-6">
            Formularz rejestracyjny Medi3
          </h1>

          <FormWizard
            client:load
            steps={steps}
            content={content}
            initialAnswers={initialAnswers}
            submissionUuid={submissionUuid}
          />
        </div>

        <div class="mt-6 text-center text-sm text-neutral-500 px-4">
          <p>Twoje dane są przetwarzane przez Fundację Medi3 zgodnie z RODO</p>
        </div>
      </div>
    </div>
  </body>
</html>
